{
  "name": "@indianic/mailman",
  "version": "1.1.0",
  "description": "MCP server for sending and reading email (Gmail via SMTP/IMAP App Password or OAuth2 Gmail API) with attachments, draft/confirm review, multi-account settings, recipient suggestions, and inbox search — usable from any Claude CLI session on macOS, Linux, or Windows.",
  "author": "kalpesh",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.indianic.in/"
  },
  "bin": {
    "mailman": "bin/mcp-mailman.js",
    "mcp-mailman": "bin/mcp-mailman.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "auth:login": "tsx src/cli/auth-login.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "release:indianic": "./scripts/release-indianic"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "email",
    "smtp",
    "gmail",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^13.0.6",
    "imapflow": "^1.0.0",
    "keytar": "^7.9.0",
    "mime-types": "^3.0.2",
    "nodemailer": "^6.9.0",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.0",
    "eslint": "^10.6.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.1"
  }
}
