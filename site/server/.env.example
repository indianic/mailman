# Copy to .env and adjust as needed.
# The server always binds to this HOST:PORT — fixed, never random.
HOST=localhost
PORT=4000

# Local Postgres — user "kalpesh", empty password.
PGHOST=localhost
PGPORT=5432
PGUSER=kalpesh
PGPASSWORD=
PGDATABASE=mailman_site

# Brand name used in emails.
BRAND=MailMan

# SendGrid — used for subscriber + lead template emails. Leave SENDGRID_API_KEY
# empty to run in "dry-run" mode (renders + logs the email, no network send) —
# handy for local dev. Set it to send for real.
SENDGRID_API_KEY=
# Must be a verified sender / domain in this SendGrid account.
SENDGRID_FROM=MailMan <no-reply@indianic.com>
